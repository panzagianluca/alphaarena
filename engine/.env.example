# OpenRouter
OPENROUTER_API_KEY=sk-or-v1-xxxx

# Hedera Testnet — Treasury (ECDSA account)
# Key must be raw hex bytes (64 chars), with or without 0x prefix
# NOT DER-encoded (no 302... prefix)
HEDERA_ACCOUNT_ID=0.0.xxxxx
HEDERA_PRIVATE_KEY=0xabc123...64-hex-chars...

# Wallet pool (generated by setup_hedera.py)
WALLET_POOL_PATH=./wallets.json

# HTS Token IDs (generated by setup_hedera.py)
TOKEN_ARENA_ID=0.0.xxxxx
TOKEN_WHBAR_ID=0.0.xxxxx
TOKEN_WBTC_ID=0.0.xxxxx
TOKEN_WETH_ID=0.0.xxxxx
TOKEN_WDOGE_ID=0.0.xxxxx

# HCS Topic IDs (generated by setup_hedera.py)
HCS_PRICE_TOPIC_ID=0.0.xxxxx
HCS_TRADES_TOPIC_ID=0.0.xxxxx
